{
  "name": "nextsql-syntax",
  "displayName": "NextSQL Language Support",
  "description": "Syntax highlighting and language server for NextSQL language",
  "version": "0.1.4",
  "publisher": "instansys",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shirakawayohane/next-sql"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "nextsql",
    "sql",
    "database",
    "query",
    "syntax"
  ],
  "icon": "icons/extension-icon.png",
  "contributes": {
    "languages": [
      {
        "id": "nextsql",
        "aliases": [
          "NextSQL",
          "nextsql"
        ],
        "extensions": [
          ".nsql"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/nsql-icon.svg",
          "dark": "./icons/nsql-icon.svg"
        }
      }
    ],
    "commands": [
      {
        "command": "nextsql.restartServer",
        "title": "NextSQL: Restart Language Server"
      },
      {
        "command": "nextsql.openSchema",
        "title": "NextSQL: Open Database Schema"
      }
    ],
    "configuration": {
      "title": "NextSQL",
      "properties": {
        "nextsql.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the nextsql-lsp binary. If empty, the extension will try to find it automatically."
        }
      }
    },
    "tomlValidation": [
      {
        "fileMatch": "next-sql.toml",
        "url": "./schemas/next-sql.schema.json"
      }
    ],
    "configurationDefaults": {
      "evenBetterToml.schema.associations": {
        "next-sql.toml": "https://schemas.nextsql.dev/next-sql.schema.json"
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "variable.other.table.nextsql",
            "settings": {
              "foreground": "#7EB8DA"
            }
          },
          {
            "scope": "variable.other.field.nextsql",
            "settings": {
              "foreground": "#9CCDE6"
            }
          }
        ]
      }
    },
    "grammars": [
      {
        "language": "nextsql",
        "scopeName": "source.nextsql",
        "path": "./syntaxes/nextsql.tmLanguage.json"
      }
    ]
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:nextsql",
    "workspaceContains:**/next-sql.toml"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && vscode-test"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.5",
    "typescript": "^5.0.0"
  }
}
