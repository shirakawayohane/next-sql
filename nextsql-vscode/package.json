{
  "name": "nextsql-syntax",
  "displayName": "NextSQL Language Support",
  "description": "Syntax highlighting and language server for NextSQL language",
  "version": "0.1.0",
  "publisher": "instansys",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shirakawayohane/next-sql"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "nextsql",
    "sql",
    "database",
    "query",
    "syntax"
  ],
  "contributes": {
    "languages": [
      {
        "id": "nextsql",
        "aliases": [
          "NextSQL",
          "nextsql"
        ],
        "extensions": [
          ".nsql"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "nextsql-toml",
        "aliases": [
          "NextSQL Config",
          "nextsql-toml"
        ],
        "extensions": [],
        "filenames": [
          "next-sql.toml"
        ]
      }
    ],
    "commands": [
      {
        "command": "nextsql.restartServer",
        "title": "NextSQL: Restart Language Server"
      }
    ],
    "grammars": [
      {
        "language": "nextsql",
        "scopeName": "source.nextsql",
        "path": "./syntaxes/nextsql.tmLanguage.json"
      }
    ]
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:nextsql",
    "onLanguage:nextsql-toml",
    "workspaceContains:**/next-sql.toml"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && vscode-test"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.5",
    "typescript": "^5.0.0"
  }
}
