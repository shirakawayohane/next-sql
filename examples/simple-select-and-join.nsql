relation author for posts returning users {
  users.id == posts.user_id
}

optional relation detail for posts returning post_details {
  post_details.id == posts.detail_id
}

relation organization for users returning users {
  users.id == users.organization_id
}

query usersPosts($id: uuid) {
  from(posts)
  .where(posts.author.organization.name == $id)
  .select(author_name: posts.author.name, organization_name: posts.author.organization.name, posts.title)
}