with amountByProducts = {
  from(transaction)
  .groupBy(transaction.product_id)
  .aggregate(
    total_amounts: SUM(transaction.amounts)
  )
  .select(transaction.product_id, total_amounts)
}

query aggregateResult {
  from(amountByProducts.innerJoin(products, amountByProducts.product_id == products.id))
  .select(products.name, total_sales: products.price * amountByProducts.total_amounts)
  .orderBy(total_sales)
}